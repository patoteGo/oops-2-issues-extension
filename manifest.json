{
  "manifest_version": 3,
  "name": "oops 2 issues",
  "version": "2.0.1",
  "description": "Capture a screenshot (full tab or region), write a markdown bug, and file it as a GitHub issue via a Personal Access Token.",
  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel",
    "scripting",
    "storage",
    "tabCapture"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open oops 2 issues",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
